# ProxyFleet baseline .gitignore

# Secrets and credentials
.env
.env.*
!.env.example
secrets/
*.key
*.pem
*.p12
*.token
*.secret

# Runtime/generated state
runtime/
cache/
releases/
build/
dist/
*.log
*.pid

# Subscription snapshots and local overrides
config-src/
providers-cache/
subscriptions-cache/
*.yaml
*.yml
!*.example.yaml
!*.example.yml
*.local.yaml
*.local.yml
*.local.json

# Salt sensitive material
salt/pki/
/etc/salt/pki/

# Editors/OS
.vscode/
.idea/
.DS_Store
*~
*.swp

# Test artifacts
.pytest_cache/
.coverage
coverage/
__pycache__/

# Local development governance and planning notes.
# These files are useful in the local workspace but should not be published.
AGENTS.md
DECISIONS.md
FILE_MANIFEST.json
PLAN.md
PROJECT_STATE.md
SOURCES.md
adr/
checkpoints/
evidence/
handoffs/
interfaces/
results/
rfcs/
tasks/
templates/
docs/GIT_OPERATIONS.md
docs/SUPPLY_CHAIN_SECURITY.md
tests/CONFIG_BUILD_TESTS.md
tests/TEST_MATRIX.md
